# CECB Environmental Clearance System — Environment Variables
# Copy this file to .env.local and fill in real values before running

# ─── Database (Supabase PostgreSQL) ──────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-256-bit-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Exposed to browser (public key only — NEVER expose KEY_SECRET here)
NEXT_PUBLIC_RAZORPAY_KEY="rzp_test_xxxxxxxxxxxx"

# ─── Uploadthing (file storage) ───────────────────────────────────
UPLOADTHING_SECRET="sk_live_xxxxxxxxxxxxxxxx"
UPLOADTHING_APP_ID="your-app-id"
